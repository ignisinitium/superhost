$TTL {{TTL}}
@       IN      SOA     {{NS1}}. hostmaster.{{MASTER_DOMAIN}}. (
                        {{SERIAL}}      ; Serial
                        3600            ; Refresh
                        1800            ; Retry
                        604800          ; Expire
                        86400 )         ; Minimum TTL

@       IN      NS      {{NS1}}.
@       IN      NS      {{NS2}}.

{{RECORDS}}
